# Required
DATABASE_URL=postgresql://user:password@host:5432/studyhub
JWT_SECRET=replace-with-strong-secret
NEXT_PUBLIC_API_URL=http://localhost:3000
# Optional for web QR card dev handoff (Expo Go):
# NEXT_PUBLIC_MOBILE_DEV_DEEP_LINK_BASE=exp://192.168.1.9:8081/--
# You can also use a template format with {userId}, e.g.
# NEXT_PUBLIC_MOBILE_DEV_DEEP_LINK_BASE=exp://192.168.1.9:8081/--/profile/{userId}
NEXT_PUBLIC_MOBILE_DEV_DEEP_LINK_BASE=
EXPO_PUBLIC_API_URL=
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
EXPO_PUBLIC_APP_ENV=development
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Cloudflare R2 (required for real profile avatar uploads)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Optional (AI)
GEMINI_API_KEY=

# Demo Credentials (seeded in DB)
# Admin: admin@studyhub.dev / admin123
# User:  user@studyhub.dev  / user123
