# Required
DATABASE_URL=postgresql://user:password@host:5432/studyhub
# Set to true only when intentionally seeding demo users into a non-production database.
ALLOW_DEMO_SEED=false
# Optional local demo seed identities. Use private reviewer credentials outside git for production.
DEMO_ADMIN_EMAIL=demo-admin@example.local
DEMO_ADMIN_NAME=Demo Admin
DEMO_ADMIN_PASSWORD=ChangeMe123!
DEMO_USER_EMAIL=demo-user@example.local
DEMO_USER_NAME=Demo User
DEMO_USER_PASSWORD=ChangeMe123!
# JWT_SECRET MUST live in .env.local (gitignored), NOT here. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
# JWT_SECRET=
# Optional separate secret for 60-second material file links; falls back to JWT_SECRET.
# FILE_LINK_SIGNING_SECRET=
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006,http://localhost:8081,http://127.0.0.1:8081
EXPO_PUBLIC_API_URL=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_REDIRECT_URI=
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
EXPO_PUBLIC_APP_ENV=development
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Optional (local integration tests)
TEST_DATABASE_URL=
TEST_BASE_URL=http://localhost:3001

# Vercel Blob - two separate stores
AVATAR_BLOB_READ_WRITE_TOKEN=
MATERIAL_BLOB_READ_WRITE_TOKEN=

# Optional (Pusher realtime)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# Optional (AI)
GEMINI_API_KEY=

# Optional (Email / contact form / share notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CONTACT_TO_EMAIL=

# Optional (Expo Push Service)
EXPO_PUSH_ACCESS_TOKEN=
