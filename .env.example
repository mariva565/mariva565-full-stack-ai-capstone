# Required
DATABASE_URL=postgresql://user:password@host:5432/studyhub
# Set to true only when intentionally seeding demo users into a non-production database.
ALLOW_DEMO_SEED=false
# JWT_SECRET MUST live in .env.local (gitignored), NOT here. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
# JWT_SECRET=
# Optional separate secret for 60-second material file links; falls back to JWT_SECRET.
# FILE_LINK_SIGNING_SECRET=
NEXT_PUBLIC_API_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006,http://localhost:8081,http://127.0.0.1:8081
EXPO_PUBLIC_API_URL=
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
EXPO_PUBLIC_APP_ENV=development
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Vercel Blob - two separate stores
AVATAR_BLOB_READ_WRITE_TOKEN=
MATERIAL_BLOB_READ_WRITE_TOKEN=

# Optional (AI)
GEMINI_API_KEY=

# Optional (Email / contact form / share notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CONTACT_TO_EMAIL=

# Optional (Expo Push Service)
EXPO_PUSH_ACCESS_TOKEN=
