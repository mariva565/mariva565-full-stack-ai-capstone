{
  "name": "studyhub-v2",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace @studyhub/web run dev",
    "prod:web": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-local-prod.ps1",
    "prod:web:skip-build": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-local-prod.ps1 -SkipBuild",
    "build:web": "npm --workspace @studyhub/web run build",
    "start:web": "npm --workspace @studyhub/web run start -- --port 3000",
    "lint:web": "npm --workspace @studyhub/web run lint",
    "typecheck:web": "npm --workspace @studyhub/web run typecheck",
    "typecheck": "npm run typecheck:web && npm run typecheck:mobile && npm run typecheck:shared",
    "deps:inventory": "npm ls --workspaces --depth=0",
    "deps:outdated": "npm outdated --workspaces",
    "deps:audit": "npm audit --audit-level=moderate",
    "deps:audit:runtime": "npm audit --omit=dev --audit-level=high",
    "deps:review:release": "npm run deps:audit:runtime",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx drizzle/seed.ts",
    "db:seed:stress": "tsx drizzle/seed-stress.ts",
    "dev:mobile": "npm --workspace @studyhub/mobile run start",
    "dev:mobile:tunnel": "npm --workspace @studyhub/mobile run start -- --tunnel -c",
    "dev:mobile:lan": "npm --workspace @studyhub/mobile run start -- --host lan",
    "dev:mobile:usb": "npm --workspace @studyhub/mobile run dev:mobile:usb",
    "dev:mobile:android:usb": "npm --workspace @studyhub/mobile run android:usb",
    "check:mojibake": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/check-mojibake.ps1",
    "hooks:install": "git config core.hooksPath .githooks",
    "typecheck:mobile": "npm --workspace @studyhub/mobile run typecheck",
    "typecheck:shared": "npm --workspace @studyhub/shared run typecheck",
    "kill:node": "taskkill //F //IM node.exe || true"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "@types/react": "~19.1.10",
    "expo": "54.0.34",
    "expo-application": "7.0.8",
    "expo-asset": "12.0.13",
    "expo-auth-session": "7.0.11",
    "expo-constants": "18.0.13",
    "expo-crypto": "15.0.9",
    "expo-file-system": "19.0.22",
    "expo-font": "14.0.11",
    "expo-keep-awake": "15.0.8",
    "expo-linking": "8.0.12",
    "expo-modules-core": "3.0.30",
    "expo-web-browser": "15.0.11",
    "@expo/fingerprint": "0.15.5",
    "@xmldom/xmldom": "0.8.13"
  },
  "devDependencies": {
    "@types/nodemailer": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.30.6",
    "next": "^15.5.18",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "canvas-confetti": "^1.9.4",
    "nodemailer": "^8.0.5",
    "react-refresh": "^0.14.2"
  }
}
