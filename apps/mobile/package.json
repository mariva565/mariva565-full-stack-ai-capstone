{
  "name": "@studyhub/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "set EXPO_NO_DEPENDENCY_VALIDATION=1&& expo start",
    "dev:mobile:tunnel": "set EXPO_NO_DEPENDENCY_VALIDATION=1&& expo start --tunnel -c",
    "dev:mobile:lan": "set EXPO_NO_DEPENDENCY_VALIDATION=1&& expo start --host lan -c",
    "usb:reverse": "node ./scripts/usb-reverse.js",
    "dev:mobile:usb": "npm run usb:reverse && set EXPO_NO_DEPENDENCY_VALIDATION=1&& expo start --localhost -c",
    "android:usb": "npm run usb:reverse && set EXPO_NO_DEPENDENCY_VALIDATION=1&& expo start --localhost --android -c",
    "android": "set EXPO_NO_DEPENDENCY_VALIDATION=1&& expo start --android",
    "ios": "set EXPO_NO_DEPENDENCY_VALIDATION=1&& expo start --ios",
    "web": "set EXPO_NO_DEPENDENCY_VALIDATION=1&& expo start --web",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/core": "^7.17.1",
    "@react-navigation/native": "^7.1.6",
    "@sentry/react-native": "~7.2.0",
    "@tanstack/query-async-storage-persister": "^5.96.2",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-query-persist-client": "^5.96.2",
    "babel-preset-expo": "~54.0.10",
    "color": "^4.2.3",
    "drizzle-kit": "0.12.8",
    "expo": "~54.0.33",
    "expo-application": "~6.1.5",
    "expo-auth-session": "^6.2.1",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~14.0.2",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-notifications": "^0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~14.0.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-qrcode-svg": "^6.3.15",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  }
}
