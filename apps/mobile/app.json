{
  "expo": {
    "name": "StudyHub v2",
    "slug": "studyhub-v2",
    "scheme": "studyhubv2",
    "version": "1.0.0",
    "icon": "./assets/branding/app-icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.studyhub.mobile",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "StudyHub uses the camera to let you photograph study materials and update your profile picture.",
        "NSPhotoLibraryUsageDescription": "StudyHub accesses your photo library to let you select images for study materials and profile pictures.",
        "NSPhotoLibraryAddUsageDescription": "StudyHub may save photos to your library."
      }
    },
    "android": {
      "package": "com.studyhub.mobile",
      "scheme": "com.studyhub.mobile",
      "versionCode": 8,
      "adaptiveIcon": {
        "foregroundImage": "./assets/branding/adaptive-icon-foreground.png",
        "backgroundColor": "#f8f6ff"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "StudyHub accesses your photos to upload study materials and profile pictures."
        }
      ],
      "expo-document-picker",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "organization": "studyhub-project",
          "project": "react-native"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "enabled": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1908016d-5259-43b9-ab21-17dd2320e3a9"
      }
    }
  }
}
