{
  "expo": {
    "name": "StudyHub v2",
    "slug": "studyhub-v2",
    "scheme": "studyhubv2",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.studyhub.mobile",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "StudyHub uses the camera to let you photograph study materials and update your profile picture.",
        "NSPhotoLibraryUsageDescription": "StudyHub accesses your photo library to let you select images for study materials and profile pictures.",
        "NSPhotoLibraryAddUsageDescription": "StudyHub may save photos to your library."
      }
    },
    "android": {
      "package": "com.studyhub.mobile",
      "versionCode": 1,
      "permissions": ["android.permission.CAMERA", "android.permission.READ_MEDIA_IMAGES", "android.permission.READ_EXTERNAL_STORAGE"]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      ["expo-image-picker", { "photosPermission": "StudyHub accesses your photos to upload study materials and profile pictures." }],
      "expo-document-picker",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "organization": "studyhub-project",
          "project": "react-native"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "enabled": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1908016d-5259-43b9-ab21-17dd2320e3a9"
      }
    }
  }
}
